---
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const logoDarkSrc = `${basePath}/buddio-wordmark.svg`;
const logoLightSrc = `${basePath}/buddio-wordmark-light.svg`;
---

<section class="relative overflow-hidden pb-20 pt-32 sm:pt-36">
  <div class="pointer-events-none absolute inset-0">
    <div class="hero-blob left-[10%] top-[12%] h-72 w-72 bg-orange-400/10 animate-pulse-glow"></div>
    <div
      class="hero-blob right-[10%] top-[18%] h-72 w-72 bg-sky-400/10 animate-pulse-glow"
      style="animation-delay: 1.5s;"
    ></div>
    <div
      class="hero-blob bottom-[-12%] left-1/2 h-72 w-72 -translate-x-1/2 bg-amber-500/10 animate-pulse-glow"
      style="animation-delay: 3s;"
    ></div>
  </div>

  <div class="relative z-10 mx-auto max-w-6xl px-6">
    <img
      src={logoLightSrc}
      alt="Buddio"
      class="mx-auto block w-full max-w-[58rem] animate-fade-in dark:hidden"
      loading="eager"
      decoding="async"
    />
    <img
      src={logoDarkSrc}
      alt="Buddio"
      class="mx-auto hidden w-full max-w-[58rem] animate-fade-in dark:block"
      loading="eager"
      decoding="async"
    />
  </div>
</section>
