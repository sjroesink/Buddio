---
import FeatureCard from "./FeatureCard.astro";

const features = [
  {
    icon: "&#9000;",
    title: "Keyboard-Only Flow",
    description:
      "Search, preview, filter by category, and execute actions without touching your mouse.",
  },
  {
    icon: "&#127919;",
    title: "Slash Command Mode",
    description:
      "Type '/' to list commands, search by name, enter parameters, and run scripts directly.",
  },
  {
    icon: "&#129302;",
    title: "AI-Created Commands",
    description:
      "No command yet? Press Enter and Buddio can ask your connected agent to create one for you.",
  },
  {
    icon: "&#128272;",
    title: "Permission Guardrails",
    description:
      "Agent tool calls are shown in-line with explicit allow/deny choices, so you stay in control.",
  },
  {
    icon: "&#128203;",
    title: "Rich Context Capture",
    description:
      "Buddio can include selected text, clipboard text, source app, and pasted images in agent prompts.",
  },
  {
    icon: "&#128161;",
    title: "Smart Suggestions",
    description:
      "When no item matches, Buddio suggests commands from history and lets you save them instantly.",
  },
  {
    icon: "&#128172;",
    title: "Conversation + Rewrite Memory",
    description:
      "Resume conversation history and quickly reuse recent rewrite prompts from selection workflows.",
  },
  {
    icon: "&#9889;",
    title: "Configurable Hotkey + Tray",
    description:
      "Set your preferred shortcut and open Buddio from the tray menu in one click.",
  },
  {
    icon: "&#62;&#95;",
    title: "Optional CLI",
    description:
      "Terminal users can still import/export or automate via buddio-cli, but the app works great without it.",
  },
];
---

<section id="features" class="relative py-32">
  <div class="mx-auto max-w-6xl px-6">
    <!-- Section header -->
    <div class="mb-16 text-center">
      <h2 class="section-heading mb-4">
        What Buddio can do
        <span class="gradient-text">right now</span>
      </h2>
      <p class="section-subheading mx-auto">
        Current launcher features, including slash commands and agent workflows.
      </p>
    </div>

    <!-- Feature grid -->
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature, i) => (
          <FeatureCard
            icon={feature.icon}
            title={feature.title}
            description={feature.description}
            delay={`${i * 0.1}s`}
          />
        ))
      }
    </div>
  </div>
</section>
