---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const useCases = [
  {
    title: "Morning standup in 20 seconds",
    description:
      "Type /summarize on yesterday's notes and paste a clean update directly into chat.",
    caption: "Turn raw notes into a polished standup post before your first meeting.",
    screenshot: `${base}/screenshots/standup-summary.svg`,
  },
  {
    title: "Jump to the right ticket instantly",
    description:
      "Search by partial issue name, hit Enter, and open the exact task without leaving flow.",
    caption: "Use one keyboard sequence to find and open active work items.",
    screenshot: `${base}/screenshots/ticket-jump.svg`,
  },
  {
    title: "Rewrite messy messages quickly",
    description:
      "Select text, run rewrite, and get a clearer version that is ready to send in one pass.",
    caption: "Clean communication without context switching to another tool.",
    screenshot: `${base}/screenshots/rewrite-message.svg`,
  },
  {
    title: "Run repetitive dev commands safely",
    description:
      "Launch your release or deploy scripts with saved parameters and visible command context.",
    caption: "Standardize recurring workflows so they stay fast and predictable.",
    screenshot: `${base}/screenshots/deploy-check.svg`,
  },
  {
    title: "Recover useful prompts from history",
    description:
      "Reopen a previous helper conversation and reuse prompts for the same type of task.",
    caption: "Keep momentum by reusing what already worked for you last time.",
    screenshot: `${base}/screenshots/history-reuse.svg`,
  },
];
---

<section id="features" class="relative pb-28 pt-10 sm:pb-32">
  <div class="mx-auto grid max-w-6xl gap-10 px-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
    <div class="space-y-4">
      {
        useCases.map((item, index) => (
          <button
            type="button"
            class={`use-case-trigger ${index === 0 ? "is-active" : ""}`}
            data-preview={item.screenshot}
            data-title={item.title}
            data-caption={item.caption}
            aria-label={`Preview example: ${item.title}`}
          >
            <span class="use-case-title">{item.title}</span>
            <span class="use-case-description">{item.description}</span>
          </button>
        ))
      }
    </div>

    <div class="glass-card feature-preview rounded-3xl p-4 sm:p-5">
      <img
        id="feature-preview-image"
        src={useCases[0].screenshot}
        alt={useCases[0].title}
        class="feature-preview-image"
        loading="lazy"
        decoding="async"
      />
      <p id="feature-preview-title" class="feature-preview-title">{useCases[0].title}</p>
      <p id="feature-preview-caption" class="feature-preview-caption">{useCases[0].caption}</p>
    </div>
  </div>
</section>

<script is:inline>
  const triggers = Array.from(document.querySelectorAll(".use-case-trigger"));
  const previewImage = document.getElementById("feature-preview-image");
  const previewTitle = document.getElementById("feature-preview-title");
  const previewCaption = document.getElementById("feature-preview-caption");

  function activate(trigger) {
    const src = trigger.getAttribute("data-preview");
    const title = trigger.getAttribute("data-title");
    const caption = trigger.getAttribute("data-caption");

    if (!src || !title || !caption) return;

    if (previewImage) {
      previewImage.setAttribute("src", src);
      previewImage.setAttribute("alt", title);
    }

    if (previewTitle) previewTitle.textContent = title;
    if (previewCaption) previewCaption.textContent = caption;

    triggers.forEach((button) => {
      button.classList.toggle("is-active", button === trigger);
    });
  }

  triggers.forEach((trigger) => {
    trigger.addEventListener("mouseenter", () => activate(trigger));
    trigger.addEventListener("focus", () => activate(trigger));
    trigger.addEventListener("click", () => activate(trigger));
  });
</script>
