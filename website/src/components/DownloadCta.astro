---
const scriptHost = "https://buddio.roesink.dev";

const installs = [
  {
    id: "windows",
    label: "Windows",
    os: "Windows",
    shell: "PowerShell",
    command: `irm ${scriptHost}/install.ps1 | iex`,
  },
  {
    id: "macos",
    label: "macOS",
    os: "macOS",
    shell: "Terminal",
    command: `curl -fsSL ${scriptHost}/install-macos.sh | bash`,
  },
  {
    id: "linux",
    label: "Linux",
    os: "Linux",
    shell: "Terminal",
    command: `curl -fsSL ${scriptHost}/install-linux.sh | bash`,
  },
];
---

<section id="download" class="relative pb-24 pt-8 sm:pb-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="download-tabs">
      <div
        class="download-tab-list"
        role="tablist"
        aria-label="Install command by operating system"
      >
        {
          installs.map((install, index) => (
            <button
              type="button"
              role="tab"
              class={`download-tab ${index === 0 ? "is-active" : ""}`}
              data-tab-id={install.id}
              data-command={install.command}
              data-shell={install.shell}
              data-os-label={install.label}
              aria-selected={index === 0 ? "true" : "false"}
              tabindex={index === 0 ? "0" : "-1"}
            >
              {
                install.id === "windows" && (
                  <svg viewBox="0 0 24 24" fill="currentColor" class="download-tab-icon" aria-hidden="true">
                    <path d="M2 3.5 10.25 2v9H2V3.5Zm9.75-1.73L22 0v11h-10.25V1.77ZM2 13h8.25v9L2 20.5V13Zm9.75 0H22v11l-10.25-1.5V13Z"></path>
                  </svg>
                )
              }
              {
                install.id === "macos" && (
                  <svg viewBox="0 0 24 24" fill="currentColor" class="download-tab-icon" aria-hidden="true">
                    <path d="M16.9 12.4c0-2.2 1.8-3.3 1.9-3.4-1-1.5-2.7-1.7-3.3-1.7-1.4-.1-2.7.8-3.4.8-.7 0-1.8-.8-3-.8-1.5 0-2.9.9-3.6 2.2-1.6 2.8-.4 6.9 1.1 9.1.7 1.1 1.6 2.3 2.8 2.3 1.1 0 1.6-.7 3-.7s1.9.7 3 .7c1.2 0 2-1.1 2.8-2.2.8-1.3 1.2-2.6 1.2-2.7 0 0-2.4-.9-2.5-3.6ZM14.8 5.8c.6-.7 1-1.7.9-2.7-.9 0-2 .6-2.7 1.3-.6.7-1.1 1.7-1 2.7 1 .1 2.1-.5 2.8-1.3Z"></path>
                  </svg>
                )
              }
              {
                install.id === "linux" && (
                  <svg viewBox="0 0 24 24" fill="currentColor" class="download-tab-icon" aria-hidden="true">
                    <path d="M12 1.5c-2.5 0-4.3 1.8-4.5 4.6-.1 1-.3 1.8-.9 2.6-1.2 1.4-2.8 3.7-2.8 6.1 0 2.6 1.9 4.7 4.5 4.7.8 0 1.6-.2 2.2-.6.6.4 1.4.6 2.2.6 2.6 0 4.5-2.1 4.5-4.7 0-2.4-1.6-4.7-2.8-6.1-.6-.8-.8-1.6-.9-2.6-.2-2.8-2-4.6-4.5-4.6Zm0 2c1.5 0 2.5 1.1 2.7 2.9.1 1.2.4 2.4 1.3 3.5 1.2 1.4 2.3 3.2 2.3 4.8 0 1.6-1.1 2.7-2.4 2.7-.7 0-1.3-.3-1.8-.8l-.6-.6-.6.6c-.5.5-1.1.8-1.8.8-1.3 0-2.4-1.1-2.4-2.7 0-1.6 1.1-3.4 2.3-4.8.9-1.1 1.2-2.3 1.3-3.5.2-1.8 1.2-2.9 2.7-2.9ZM9.4 12a1 1 0 1 1 0 2 1 1 0 0 1 0-2Zm5.2 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2Z"></path>
                  </svg>
                )
              }
              {install.label}
            </button>
          ))
        }
      </div>

      <div class="download-panel" role="tabpanel">
        <div class="download-meta-row">
          <p id="download-shell-label" class="download-shell-label">{installs[0].shell}</p>
          <p id="download-os-label" class="download-os-label">{installs[0].label}</p>
        </div>

        <div class="download-command-row">
          <code id="download-command" class="download-command">{installs[0].command}</code>
          <button
            id="download-copy"
            type="button"
            class="copy-btn"
            data-copy={installs[0].command}
            aria-label={`Copy ${installs[0].os} install command`}
          >
            Copy
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const tabButtons = Array.from(document.querySelectorAll(".download-tab"));
  const shellLabel = document.getElementById("download-shell-label");
  const osLabel = document.getElementById("download-os-label");
  const commandNode = document.getElementById("download-command");
  const copyButton = document.getElementById("download-copy");

  function detectTabIdFromOs() {
    const platform = (navigator.platform || "").toLowerCase();
    const userAgent = (navigator.userAgent || "").toLowerCase();

    if (platform.includes("win")) return "windows";
    if (
      platform.includes("mac") ||
      userAgent.includes("mac os") ||
      userAgent.includes("darwin")
    ) {
      return "macos";
    }
    if (platform.includes("linux") || userAgent.includes("linux")) return "linux";
    return null;
  }

  function activateTab(tabId) {
    const active = tabButtons.find((button) => button.dataset.tabId === tabId) || tabButtons[0];
    if (!active) return;

    const command = active.dataset.command || "";
    const shell = active.dataset.shell || "";
    const os = active.dataset.osLabel || "";

    tabButtons.forEach((button) => {
      const isActive = button === active;
      button.classList.toggle("is-active", isActive);
      button.setAttribute("aria-selected", String(isActive));
      button.tabIndex = isActive ? 0 : -1;
    });

    if (commandNode) commandNode.textContent = command;
    if (shellLabel) shellLabel.textContent = shell;
    if (osLabel) osLabel.textContent = os;
    if (copyButton) {
      copyButton.setAttribute("data-copy", command);
      copyButton.setAttribute("aria-label", `Copy ${os} install command`);
    }
  }

  tabButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const tabId = button.dataset.tabId;
      if (tabId) activateTab(tabId);
    });
  });

  activateTab(detectTabIdFromOs() || tabButtons[0]?.dataset.tabId || "windows");

  function copyText(command) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      return navigator.clipboard.writeText(command);
    }

    const area = document.createElement("textarea");
    area.value = command;
    area.style.position = "fixed";
    area.style.opacity = "0";
    document.body.appendChild(area);
    area.focus();
    area.select();
    document.execCommand("copy");
    document.body.removeChild(area);
    return Promise.resolve();
  }

  copyButton?.addEventListener("click", async () => {
    const command = copyButton.getAttribute("data-copy");
    if (!command) return;

    const original = copyButton.textContent;

    try {
      await copyText(command);
      copyButton.textContent = "Copied";
    } catch {
      copyButton.textContent = "Failed";
    }

    setTimeout(() => {
      copyButton.textContent = original;
    }, 1200);
  });
</script>
