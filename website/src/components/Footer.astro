---
const year = new Date().getFullYear();
const logoSrc = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/buddio-wordmark.svg`;
---

<footer class="border-t border-white/10 bg-[#2b1a0f] py-8 text-amber-100/80">
  <div
    class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 sm:flex-row"
  >
    <!-- Left -->
    <div class="flex items-center gap-3 text-sm">
      <img
        src={logoSrc}
        alt="Buddio"
        class="h-7 w-auto opacity-95"
        loading="lazy"
        decoding="async"
      />
      <span>&copy; {year}</span>
      <span class="opacity-40">&middot;</span>
      <span>MIT License</span>
    </div>

    <!-- Right -->
    <div class="flex items-center gap-4">
      <a
        href="https://github.com/sjroesink/Buddio"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-amber-100/75 transition-colors hover:text-white"
      >
        GitHub
      </a>
      <a
        href="https://github.com/sjroesink/Buddio/releases"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-amber-100/75 transition-colors hover:text-white"
      >
        Releases
      </a>
      <a
        href="https://github.com/sjroesink/Buddio/issues"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-amber-100/75 transition-colors hover:text-white"
      >
        Issues
      </a>
    </div>
  </div>
</footer>
